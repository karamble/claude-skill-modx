# Block all HTTP access to this directory.
# The MODX CLI bridge lives here and must never be served over the web.
# A PHP_SAPI guard inside modx-cli.php provides belt-and-suspenders.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
